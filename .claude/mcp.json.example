{
  "_comment": "Copy this file to .mcp.json (gitignored) and fill in the ${...} env vars / tokens. Declares the MCP servers this repo uses: postgres-local and postgres (local + Supabase Postgres via @modelcontextprotocol/server-postgres), vercel/render/stripe/stitch/sentry (hosted HTTP integrations), sonarqube (Dockerized), and csharp-lsp — the Roslyn-backed CWM.RoslynNavigator MCP server (install once with `dotnet tool install -g CWM.RoslynNavigator`; needs the .NET 10 SDK) pointed at orbit-api's Orbit.slnx via --solution, giving Claude symbol-precise C# navigation across orbit-api even when this session is launched from orbit-ui-mobile. chrome-devtools (chrome-devtools-mcp) is project-scoped here on purpose: it powers /profile's perf traces and is deliberately NOT a global MCP, so day-to-day browser driving uses the native Claude-in-Chrome integration instead.",
  "mcpServers": {
    "postgres-local": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-postgres", "${LOCAL_POSTGRES_URL}"],
      "env": {},
      "timeout": 45000
    },
    "postgres": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-postgres", "${SUPABASE_POSTGRES_URL}"],
      "env": {},
      "timeout": 45000
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com"
    },
    "render": {
      "type": "http",
      "url": "https://mcp.render.com/mcp",
      "headers": {
        "Authorization": "Bearer ${RENDER_MCP_TOKEN}"
      }
    },
    "stripe": {
      "type": "http",
      "url": "https://mcp.stripe.com"
    },
    "sonarqube": {
      "command": "docker",
      "args": ["run", "--init", "--pull=always", "-i", "--rm", "-e", "SONARQUBE_TOKEN", "-e", "SONARQUBE_ORG", "mcp/sonarqube"],
      "env": {
        "SONARQUBE_TOKEN": "${SONARQUBE_TOKEN}",
        "SONARQUBE_ORG": "${SONARQUBE_ORG}"
      },
      "timeout": 120000
    },
    "stitch": {
      "type": "http",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "${STITCH_API_KEY}"
      }
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "csharp-lsp": {
      "command": "C:/Users/thoma/.dotnet/tools/cwm-roslyn-navigator.exe",
      "args": ["--solution", "C:/Users/thoma/Documents/Programming/Projects/orbit-api/Orbit.slnx"],
      "timeout": 60000
    },
    "chrome-devtools": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "chrome-devtools-mcp@latest"],
      "env": {
        "SystemRoot": "C:\\Windows",
        "PROGRAMFILES": "C:\\Program Files"
      }
    }
  }
}
