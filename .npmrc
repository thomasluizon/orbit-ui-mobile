# react-native-worklets is pinned to 0.10.0 (the version Reanimated 4.5.0 is built
# against) via `overrides`, matching the Expo SDK 57 bundled native module set.
# Reanimated and worklets share a native ABI and must stay locked together; letting
# npm "fix" worklets to a newer patch to satisfy an advisory peer range would break
# reanimated at runtime. legacy-peer-deps tolerates those advisory peer mismatches.
legacy-peer-deps=true
