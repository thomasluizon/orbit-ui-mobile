# react-native-worklets is pinned to 0.7.2 (the version Reanimated 4.2.1 is built
# against) via `overrides`. Expo SDK 55's expo-modules-core declares an advisory
# peer of ^0.7.4 || ^0.8.0, so a from-scratch resolve would otherwise ERESOLVE.
# 0.7.2 is the version reanimated 4.2.1's native code is built against, so we
# tolerate the peer mismatch instead of letting npm "fix" it back to 0.7.4.
legacy-peer-deps=true
