{
  "name": "@orbit/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "postinstall": "node scripts/fix-hoisting.js",
    "dev": "expo start",
    "dev:client": "node scripts/run-dev-client.js",
    "build:android": "eas build --platform android",
    "android:build-apk": "eas build --platform android --profile preview",
    "android:build-aab": "eas build --platform android --profile production",
    "android:release-apk": "cd android && EXPO_NO_METRO_WORKSPACE_ROOT=1 ./gradlew assembleRelease",
    "android:device": "node scripts/android-release-device.js",
    "build:ios": "eas build --platform ios",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "lint": "expo lint",
    "clean": "rm -rf .expo",
    "android": "node scripts/run-android.js",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.1.0",
    "@hookform/resolvers": "^4.1.0",
    "@orbit/shared": "*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/native": "^7.0.14",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.75.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.0",
    "expo-clipboard": "~8.0.7",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "^3.1.2",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "fs-extra": "^11.3.4",
    "i18next": "^24.2.0",
    "lucide-react-native": "^0.475.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-hook-form": "^7.54.0",
    "react-i18next": "^15.4.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.10",
    "@vitest/coverage-v8": "^3.2.4",
    "react-test-renderer": "^19.1.0",
    "tailwindcss": "3.4.17",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  }
}
