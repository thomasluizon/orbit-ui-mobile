{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://api.useorbit.org",
        "EXPO_PUBLIC_ADMOB_USE_TEST_IDS": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://api.useorbit.org",
        "EXPO_PUBLIC_ADMOB_USE_TEST_IDS": "true"
      }
    },
    "production": {
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://api.useorbit.org",
        "EXPO_PUBLIC_ADMOB_USE_TEST_IDS": "false",
        "EXPO_PUBLIC_ADMOB_ANDROID_APP_ID": "ca-app-pub-8521676951882691~5595921738",
        "EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL_ID": "ca-app-pub-8521676951882691/8083010939",
        "EXPO_PUBLIC_ADMOB_ANDROID_REWARDED_ID": "ca-app-pub-8521676951882691/3704782221"
      }
    }
  },
  "submit": {
    "internal": {
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "internal",
        "releaseStatus": "completed"
      }
    },
    "closed": {
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "alpha",
        "releaseStatus": "completed"
      }
    },
    "open": {
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "beta",
        "releaseStatus": "completed"
      }
    },
    "production": {
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "production",
        "releaseStatus": "completed"
      }
    }
  }
}
