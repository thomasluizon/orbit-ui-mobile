{
  "expo": {
    "name": "Orbit",
    "slug": "orbit",
    "version": "1.1.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "orbit",
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#020618"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.useorbit.app"
    },
    "android": {
      "icon": "./assets/icon.png",
      "playStoreUrl": "https://play.google.com/store/apps/details?id=org.useorbit.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#22094f"
      },
      "versionCode": 30,
      "package": "org.useorbit.app",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "https",
              "host": "app.useorbit.org",
              "pathPrefix": "/auth-callback"
            }
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "https",
              "host": "app.useorbit.org",
              "pathPrefix": "/r/"
            }
          ]
        }
      ],
      "permissions": [
        "INTERNET",
        "POST_NOTIFICATIONS",
        "RECORD_AUDIO",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "com.google.android.gms.permission.AD_ID",
        "com.android.vending.BILLING"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-dev-client",
        {
          "launchMode": "launcher",
          "android": {
            "launchMode": "launcher"
          }
        }
      ],
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7f46f7"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos so you can attach images in AI chat.",
          "cameraPermission": false
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "delayAppMeasurementInit": true
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to record voice input for AI chat."
        }
      ],
      [
        "@siteed/audio-studio",
        {
          "enableNotifications": false,
          "enableBackgroundAudio": false,
          "enableDeviceDetection": false,
          "enablePhoneStateHandling": false,
          "iosBackgroundModes": { "useAudio": false }
        }
      ],
      "expo-sqlite",
      "expo-iap",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "organization": "thomasluizon",
          "project": "orbit-mobile"
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://app.useorbit.org"
      },
      "eas": {
        "projectId": "84b3535b-5957-42b7-bda3-4ed9dfde3734"
      }
    }
  }
}
