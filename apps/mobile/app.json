{
  "expo": {
    "name": "Orbit",
    "slug": "orbit",
    "version": "1.1.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "orbit",
    "newArchEnabled": true,
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#07060e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.useorbit.app"
    },
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a0a2e"
      },
      "versionCode": 27,
      "package": "org.useorbit.app",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "https",
              "host": "app.useorbit.org",
              "pathPrefix": "/auth-callback"
            }
          ]
        }
      ],
      "permissions": [
        "INTERNET",
        "POST_NOTIFICATIONS",
        "RECORD_AUDIO",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-dev-client",
        {
          "launchMode": "launcher",
          "android": {
            "launchMode": "launcher"
          }
        }
      ],
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#8b5cf6"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos so you can attach images in AI chat.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to use the microphone for voice input in AI chat.",
          "speechRecognitionPermission": "Allow $(PRODUCT_NAME) to use speech recognition for voice input in AI chat.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox",
            "com.google.android.tts",
            "com.google.android.as"
          ]
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://app.useorbit.org"
      },
      "eas": {
        "projectId": "84b3535b-5957-42b7-bda3-4ed9dfde3734"
      }
    }
  }
}
