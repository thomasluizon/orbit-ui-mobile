<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="44dp">

    <!-- Dynamic background (rendered programmatically with theme colors) -->
    <ImageView
        android:id="@+id/item_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@null" />

    <RelativeLayout
        android:id="@+id/widget_item_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="11dp"
        android:paddingBottom="11dp"
        android:minHeight="44dp">

        <!-- Left indicator container: holds either circle or progress badge -->
        <FrameLayout
            android:id="@+id/item_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:minWidth="22dp"
            android:minHeight="22dp">

            <!-- Status circle -->
            <ImageView
                android:id="@+id/item_status_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/widget_circle_empty"
                android:contentDescription="Status" />

            <!-- Progress badge for parents -->
            <TextView
                android:id="@+id/item_progress_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/widget_progress_background"
                android:textColor="#FFc084fc"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Checklist badge (far right) -->
        <TextView
            android:id="@+id/item_checklist_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_badge_background"
            android:textColor="#FF8b5cf6"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone" />

        <!-- Title + time stacked vertically -->
        <LinearLayout
            android:id="@+id/item_title_time_col"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/item_indicator"
            android:layout_toStartOf="@id/item_checklist_badge"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:id="@+id/item_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFf0eef6"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium" />

            <!-- Due time (below title, plain text) -->
            <TextView
                android:id="@+id/item_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#997a7490"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:paddingTop="1dp"
                android:visibility="gone" />

        </LinearLayout>

    </RelativeLayout>
</FrameLayout>
