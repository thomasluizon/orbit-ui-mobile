<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Dynamic background (rendered programmatically with theme colors) -->
    <ImageView
        android:id="@+id/widget_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@null" />

    <LinearLayout
        android:id="@+id/widget_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header row -->
        <RelativeLayout
            android:id="@+id/widget_header_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="2dp">

            <!-- Left: dot + text column -->
            <LinearLayout
                android:id="@+id/widget_header_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@id/widget_header_right"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/widget_header_dot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/widget_header_dot"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:id="@+id/widget_header_text_col"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/widget_header"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today"
                        android:textColor="#FFFFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.02" />

                    <TextView
                        android:id="@+id/widget_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#997a7490"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingTop="1dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right: streak + refresh -->
            <LinearLayout
                android:id="@+id/widget_header_right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Flame icon (set programmatically, no android:src) -->
                <ImageView
                    android:id="@+id/widget_flame"
                    android:layout_width="14dp"
                    android:layout_height="16dp"
                    android:contentDescription="@null"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/widget_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:textColor="#FFf97316"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="gone" />

                <!-- Refresh button -->
                <ImageView
                    android:id="@+id/widget_refresh"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/widget_refresh_icon"
                    android:padding="6dp"
                    android:contentDescription="Refresh" />

                <!-- Loading spinner (shown during refresh, hidden by default) -->
                <ProgressBar
                    android:id="@+id/widget_refresh_loading"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="6dp"
                    android:indeterminateTint="#AA8b5cf6"
                    android:visibility="gone" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Spacer -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="10dp" />

        <!-- Habit list -->
        <ListView
            android:id="@+id/widget_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@null"
            android:dividerHeight="6dp"
            android:scrollbars="vertical"
            android:fadeScrollbars="true"
            android:scrollbarThumbVertical="@drawable/widget_scrollbar_thumb"
            android:fadingEdge="none"
            android:clipToPadding="false" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/widget_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_empty_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All clear!"
                android:textColor="#997a7490"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
