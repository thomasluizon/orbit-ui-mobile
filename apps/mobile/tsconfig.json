{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "ES2022"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "nativewind",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@orbit/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@orbit/shared/*": [
        "../../packages/shared/src/*"
      ],
      "react-native": [
        "./node_modules/react-native"
      ],
      "react-native/*": [
        "./node_modules/react-native/*"
      ]
    },
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
