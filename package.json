{
  "name": "orbit",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "web": "turbo run dev --filter=@orbit/web",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@swc/helpers": "^0.5.15",
    "fdir": "^6.5.0",
    "html-parse-stringify": "^3.0.1",
    "indent-string": "^4.0.0",
    "min-indent": "^1.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-test-renderer": "19.2.0",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "^1.0.0-rc.13",
    "@rolldown/binding-win32-x64-msvc": "^1.0.0-rc.13"
  },
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-test-renderer": "19.2.0"
  }
}
