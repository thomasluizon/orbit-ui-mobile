{
  "name": "orbit",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "lefthook install || true",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "web": "turbo run dev --filter=@orbit/web",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@swc/helpers": "^0.5.15",
    "ajv": "^8.20.0",
    "commander": "~15.0.0",
    "fdir": "^6.5.0",
    "html-parse-stringify": "^3.0.1",
    "indent-string": "^4.0.0",
    "lefthook": "^2.1.10",
    "min-indent": "^1.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-test-renderer": "19.2.7",
    "turbo": "^2.9.18",
    "typescript": "^6.0.2"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "^1.0.0-rc.13",
    "@rolldown/binding-win32-x64-msvc": "^1.0.0-rc.13"
  },
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-test-renderer": "19.2.7",
    "react-native-worklets": "0.10.0",
    "expo": "57.0.4",
    "expo-application": "57.0.0",
    "expo-asset": "57.0.3",
    "expo-constants": "57.0.3",
    "expo-dev-client": "57.0.5",
    "expo-dev-launcher": "57.0.5",
    "expo-dev-menu": "57.0.5",
    "expo-device": "57.0.0",
    "expo-file-system": "57.0.0",
    "expo-font": "57.0.0",
    "expo-image-loader": "57.0.0",
    "expo-image-picker": "57.0.2",
    "expo-keep-awake": "57.0.0",
    "expo-linear-gradient": "57.0.0",
    "expo-linking": "57.0.2",
    "expo-notifications": "57.0.3",
    "expo-router": "57.0.4",
    "expo-secure-store": "57.0.0",
    "expo-speech": "57.0.0",
    "expo-sqlite": "57.0.0",
    "expo-store-review": "57.0.0",
    "expo-web-browser": "57.0.0",
    "underscore": "^1.13.8"
  }
