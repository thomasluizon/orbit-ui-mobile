packages/shared/src/types/__generated__/*.generated.ts text eol=lf
.claude/workflows/*.mjs text eol=lf
.claude/skills/**/*.mjs text eol=lf
tools/*.sh text eol=lf
apps/web/e2e/visual/__screenshots__/**/*.png filter=lfs diff=lfs merge=lfs -text
# Machine-parsed harness artifacts and node scripts check out as LF everywhere:
# core.autocrlf=true materialized the committed work orders with CRLF on a fresh
# Windows clone and drive-queue parsed ZERO of the 214 orders on disk. The
# parsers are CRLF-tolerant too (belt), this pins the checkout (suspenders).
# .claude/drive/ is gitignored, so it needs no rule.
.claude/workorders/*.md text eol=lf
*.mjs text eol=lf
# arch-map artifacts are regenerated by CI and diffed byte-for-byte; a CRLF
# checkout would make the drift gate compare different bytes than the LF the
# generator writes.
architecture.json text eol=lf
architecture.html text eol=lf
