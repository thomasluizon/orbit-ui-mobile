{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "WORKFLOW.md",
    "DESIGN.md",
    "apps/*/CLAUDE.md",
    "packages/*/CLAUDE.md",
    "~/Documents/Programming/Projects/orbit-api/CLAUDE.md",
    "~/Documents/Programming/Projects/orbit-landing-page/CLAUDE.md"
  ],
  "mcp": {
    "postgres-local": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "@modelcontextprotocol/server-postgres", "{env:LOCAL_POSTGRES_URL}"],
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "@modelcontextprotocol/server-postgres", "{env:SUPABASE_POSTGRES_URL}"],
      "enabled": true
    },
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "enabled": true
    },
    "render": {
      "type": "remote",
      "url": "https://mcp.render.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:RENDER_MCP_TOKEN}"
      }
    },
    "stripe": {
      "type": "remote",
      "url": "https://mcp.stripe.com",
      "enabled": true
    },
    "sonarqube": {
      "type": "local",
      "command": ["docker", "run", "--init", "--pull=always", "-i", "--rm", "-e", "SONARQUBE_TOKEN", "-e", "SONARQUBE_ORG", "mcp/sonarqube"],
      "enabled": true,
      "environment": {
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN}",
        "SONARQUBE_ORG": "{env:SONARQUBE_ORG}"
      }
    },
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "{env:STITCH_API_KEY}"
      }
    },
    "csharp-lsp": {
      "type": "local",
      "command": ["node", ".claude/scripts/csharp-lsp.mjs"],
      "enabled": true,
      "environment": {
        "ORBIT_API_ROOT": "C:/Users/thoma/Documents/Programming/Projects/orbit-api"
      }
    }
  }
}
