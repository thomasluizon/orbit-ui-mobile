# Dependencies
node_modules/

# Build outputs
dist/
.next/
.expo/
.turbo/
*.tsbuildinfo

# Environment
.env
.env.local
.env.*.local
/env

# IDE
.vscode/
.idea/
.claude/worktrees/
# Plans are the contract source the committed work orders point at (their
# generatedFrom frontmatter): ignoring the whole dir left every fresh checkout
# with plan bundles whose Tier and acceptance criteria named a file that did
# not exist. The *.plan.md files ride the branch; everything else stays local.
.claude/plans/*
!.claude/plans/*.plan.md
.claude/reviews/
.claude/reports/
.claude/audits/
.claude/drive/
.mcp.json
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Coverage
coverage/
coverage-*/

# Mutation testing (StrykerJS)
.stryker-tmp/
packages/shared/.stryker-tmp/
packages/shared/reports/

# Playwright smoke (apps/web/e2e)
apps/web/e2e/.auth/
apps/web/e2e/.report/
apps/web/e2e/.results/
/test-results/
.cache/ms-playwright/

# Temporary files
.tmp/
temporary screenshots/

# Screenshots are bulk binary evidence: regenerable, never committed.
# The DURABLE evidence the oracle reads - the surface inventory, the defect
# reports and the human sign-off - lives in .claude/manifests/ and IS
# committed. Ignoring it was the mechanism behind "attempt N+1 rediscovers
# attempt N": six sessions each rebuilt a denominator the last one had
# already derived, because nothing survived the session boundary.
.artifacts/

# Expo
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
google-services.json
apps/mobile/play-service-account.json

# Native build outputs
apps/mobile/android/
apps/mobile/modules/*/android/.gradle/
apps/mobile/modules/*/android/.cxx/
apps/mobile/modules/*/android/build/
apps/mobile/modules/*/android/local.properties
apps/mobile/ios/

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

.claude/sweeps/

# foglamp scan (edit token in scan.lock.json is a secret)
.foglamp/
.tmp_session_text.txt
